<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>To-Do List Application</title>


    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }


        body {
            min-height: 100vh;
            font-family: Arial, sans-serif;
            background-color: #fff1f2;
            color: #4c0519;
            padding: 40px 20px;
        }


        /* MAIN CONTAINER */

        .container {
            max-width: 800px;
            margin: auto;
        }


        /* HEADER */

        .header {
            text-align: center;
            margin-bottom: 30px;
        }


        .header h1 {
            font-size: 38px;
            color: #881337;
            margin-bottom: 8px;
        }


        .header p {
            color: #9f1239;
            font-size: 15px;
        }


        /* APP CARD */

        .todo-app {
            background-color: white;
            padding: 35px;
            border-radius: 20px;
            box-shadow: 0 12px 35px rgba(136, 19, 55, 0.15);
        }


        /* INPUT SECTION */

        .input-section {
            display: flex;
            gap: 12px;
            margin-bottom: 30px;
        }


        #taskInput {
            flex: 1;
            padding: 14px 18px;
            border: 2px solid #fecdd3;
            border-radius: 10px;
            outline: none;
            font-size: 15px;
            transition: 0.3s;
        }


        #taskInput:focus {
            border-color: #e11d48;
            box-shadow: 0 0 7px rgba(225, 29, 72, 0.2);
        }


        .add-button {
            padding: 14px 25px;
            border: none;
            border-radius: 10px;
            background-color: #e11d48;
            color: white;
            font-size: 15px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }


        .add-button:hover {
            background-color: #be123c;
            transform: translateY(-2px);
        }


        /* TASK INFORMATION */

        .task-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: #fff1f2;
            padding: 15px 20px;
            border-radius: 10px;
            margin-bottom: 20px;
        }


        .task-info p {
            color: #881337;
            font-weight: bold;
        }


        .task-count {
            background-color: #e11d48;
            color: white;
            padding: 7px 14px;
            border-radius: 20px;
            font-size: 13px;
        }


        /* EMPTY MESSAGE */

        #emptyMessage {
            text-align: center;
            color: #9ca3af;
            padding: 45px 10px;
        }


        #emptyMessage h2 {
            color: #be123c;
            margin-bottom: 8px;
        }


        /* TASK LIST */

        #taskList {
            list-style: none;
        }


        /* TASK ITEM */

        .task-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 17px 18px;
            margin-bottom: 12px;
            background-color: #fff7f8;
            border: 1px solid #fecdd3;
            border-left: 5px solid #e11d48;
            border-radius: 10px;
            transition: 0.3s;
        }


        .task-item:hover {
            transform: translateX(4px);
            box-shadow: 0 5px 15px rgba(136, 19, 55, 0.1);
        }


        /* TASK CONTENT */

        .task-content {
            flex: 1;
        }


        .task-text {
            font-size: 16px;
            color: #4c0519;
            font-weight: bold;
        }


        .task-number {
            display: block;
            font-size: 12px;
            color: #9f1239;
            margin-top: 4px;
        }


        /* COMPLETED TASK */

        .completed .task-text {
            text-decoration: line-through;
            color: #9ca3af;
        }


        .completed {
            background-color: #f3f4f6;
            border-left-color: #22c55e;
            opacity: 0.8;
        }


        /* BUTTON SECTION */

        .task-buttons {
            display: flex;
            gap: 7px;
            margin-left: 15px;
        }


        .task-buttons button {
            padding: 8px 11px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 12px;
            font-weight: bold;
            transition: 0.3s;
        }


        .complete-button {
            background-color: #dcfce7;
            color: #166534;
        }


        .complete-button:hover {
            background-color: #bbf7d0;
        }


        .edit-button {
            background-color: #fef3c7;
            color: #92400e;
        }


        .edit-button:hover {
            background-color: #fde68a;
        }


        .delete-button {
            background-color: #fee2e2;
            color: #991b1b;
        }


        .delete-button:hover {
            background-color: #fecaca;
        }


        /* FOOTER MESSAGE */

        .footer-message {
            text-align: center;
            margin-top: 25px;
            color: #9f1239;
            font-size: 13px;
        }


        /* RESPONSIVE DESIGN */

        @media (max-width: 650px) {

            .input-section {
                flex-direction: column;
            }


            .add-button {
                width: 100%;
            }


            .task-item {
                flex-direction: column;
                align-items: flex-start;
            }


            .task-buttons {
                margin-left: 0;
                margin-top: 15px;
                width: 100%;
            }


            .task-buttons button {
                flex: 1;
            }

        }


    </style>

</head>


<body>


    <div class="container">


        <!-- HEADER -->

        <div class="header">

            <h1>My Task Manager</h1>

            <p>
                Organize your tasks and stay productive.
            </p>

        </div>



        <!-- TO-DO APPLICATION -->

        <div class="todo-app">


            <!-- INPUT SECTION -->

            <div class="input-section">

                <input
                    type="text"
                    id="taskInput"
                    placeholder="Enter a new task..."
                >


                <button
                    class="add-button"
                    onclick="addTask()"
                >

                    Add Task

                </button>

            </div>



            <!-- TASK INFORMATION -->

            <div class="task-info">

                <p>Your Tasks</p>


                <div class="task-count">

                    Total Tasks:

                    <span id="taskCount">0</span>

                </div>

            </div>



            <!-- EMPTY MESSAGE -->

            <div id="emptyMessage">

                <h2>No Tasks Yet</h2>

                <p>
                    Add your first task using the input box above.
                </p>

            </div>



            <!-- TASK LIST -->

            <ul id="taskList"></ul>



            <!-- FOOTER -->

            <div class="footer-message">

                Add, edit, complete or delete your daily tasks.

            </div>


        </div>


    </div>



    <script>


        /* ---------------------------------

           GLOBAL VARIABLE

        --------------------------------- */


        let taskCounter = 0;



        /* ---------------------------------

           ADD TASK FUNCTION

           DOM CREATION AND UPDATE

        --------------------------------- */


        function addTask() {


            let taskInput =

                document.getElementById("taskInput");


            let taskText =

                taskInput.value.trim();



            /* INPUT VALIDATION */


            if (taskText === "") {


                alert("Please enter a task.");


                return;

            }



            /* GET TASK LIST */


            let taskList =

                document.getElementById("taskList");



            /* CREATE NEW LI ELEMENT */


            let listItem =

                document.createElement("li");



            /* ADD CLASS */


            listItem.classList.add("task-item");



            /* CREATE TASK CONTENT DIV */


            let taskContent =

                document.createElement("div");


            taskContent.classList.add("task-content");



            /* CREATE TASK TEXT */


            let textElement =

                document.createElement("span");


            textElement.classList.add("task-text");


            textElement.textContent = taskText;



            /* CREATE TASK NUMBER */


            let numberElement =

                document.createElement("small");


            numberElement.classList.add("task-number");



            /* UPDATE COUNTER */


            taskCounter++;


            numberElement.textContent =

                "Task #" + taskCounter;



            /* ADD ELEMENTS USING appendChild() */


            taskContent.appendChild(textElement);


            taskContent.appendChild(numberElement);



            /* CREATE BUTTON CONTAINER */


            let buttonContainer =

                document.createElement("div");


            buttonContainer.classList.add("task-buttons");



            /* CREATE COMPLETE BUTTON */


            let completeButton =

                document.createElement("button");


            completeButton.textContent = "Complete";


            completeButton.classList.add("complete-button");


            completeButton.onclick = function() {


                completeTask(this);

            };



            /* CREATE EDIT BUTTON */


            let editButton =

                document.createElement("button");


            editButton.textContent = "Edit";


            editButton.classList.add("edit-button");


            editButton.onclick = function() {


                editTask(this);

            };



            /* CREATE DELETE BUTTON */


            let deleteButton =

                document.createElement("button");


            deleteButton.textContent = "Delete";


            deleteButton.classList.add("delete-button");


            deleteButton.onclick = function() {


                deleteTask(this);

            };



            /* ADD BUTTONS TO CONTAINER */


            buttonContainer.appendChild(completeButton);


            buttonContainer.appendChild(editButton);


            buttonContainer.appendChild(deleteButton);



            /* ADD CONTENT AND BUTTONS TO LI */


            listItem.appendChild(taskContent);


            listItem.appendChild(buttonContainer);



            /* ADD LI TO TASK LIST */


            taskList.appendChild(listItem);



            /* CLEAR INPUT */


            taskInput.value = "";



            /* UPDATE TASK INFORMATION */


            updateTaskInformation();



            /* CONSOLE OUTPUT */


            console.log(

                "Task Added:",

                taskText

            );


        }




        /* ---------------------------------

           COMPLETE TASK FUNCTION

           DOM TRAVERSAL USING parentElement

        --------------------------------- */


        function completeTask(button) {


            /* BUTTON -> BUTTON CONTAINER */


            let buttonContainer =

                button.parentElement;



            /* BUTTON CONTAINER -> LI */


            let taskItem =

                buttonContainer.parentElement;



            /* UPDATE CLASS */


            taskItem.classList.toggle("completed");



            /* DOM TRAVERSAL USING children */


            let taskContent =

                taskItem.children[0];



            let taskText =

                taskContent.children[0].textContent;



            console.log(

                "Task Status Changed:",

                taskText

            );


        }




        /* ---------------------------------

           EDIT TASK FUNCTION

           DOM TRAVERSAL

        --------------------------------- */


        function editTask(button) {


            /* TRAVERSE TO PARENT ELEMENT */


            let buttonContainer =

                button.parentElement;



            let taskItem =

                buttonContainer.parentElement;



            /* ACCESS FIRST CHILD */


            let taskContent =

                taskItem.children[0];



            let textElement =

                taskContent.children[0];



            /* GET CURRENT TEXT */


            let currentText =

                textElement.textContent;



            /* GET NEW TEXT */


            let newText = prompt(

                "Edit your task:",

                currentText

            );



            /* VALIDATION */


            if (

                newText !== null &&

                newText.trim() !== ""

            ) {


                /* UPDATE DOM CONTENT */


                textElement.textContent =

                    newText.trim();



                console.log(

                    "Task Updated:",

                    newText

                );


            }


        }




        /* ---------------------------------

           DELETE TASK FUNCTION

           DOM TRAVERSAL AND REMOVAL

        --------------------------------- */


        function deleteTask(button) {


            /* TRAVERSE FROM BUTTON TO LI */


            let buttonContainer =

                button.parentElement;



            let taskItem =

                buttonContainer.parentElement;



            /* ACCESS TASK TEXT USING children */


            let taskText =

                taskItem.children[0]

                    .children[0]

                    .textContent;



            /* DELETE ELEMENT */


            taskItem.remove();



            /* UPDATE INFORMATION */


            updateTaskInformation();



            console.log(

                "Task Deleted:",

                taskText

            );


        }




        /* ---------------------------------

           UPDATE TASK INFORMATION

        --------------------------------- */


        function updateTaskInformation() {


            let taskList =

                document.getElementById("taskList");



            /* DOM PROPERTY children */


            let totalTasks =

                taskList.children.length;



            /* DISPLAY TOTAL TASKS */


            document.getElementById(

                "taskCount"

            ).textContent = totalTasks;



            /* SHOW OR HIDE EMPTY MESSAGE */


            let emptyMessage =

                document.getElementById("emptyMessage");



            if (totalTasks === 0) {


                emptyMessage.style.display = "block";


            }


            else {


                emptyMessage.style.display = "none";


            }


        }




        /* ---------------------------------

           ENTER KEY SUPPORT

        --------------------------------- */


        document.getElementById(

            "taskInput"

        ).addEventListener(

            "keypress",

            function(event) {


                if (event.key === "Enter") {


                    addTask();


                }


            }

        );


    </script>


</body>

</html>
