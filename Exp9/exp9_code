<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>User Preference Manager</title>


    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }


        :root {
            --accent-color: #7c3aed;
        }


        body {
            min-height: 100vh;
            font-family: Arial, sans-serif;
            background-color: #f3f4f6;
            color: #1f2937;
            transition: 0.3s;
        }


        /* DARK THEME */

        body.dark-theme {
            background-color: #111827;
            color: #f9fafb;
        }


        /* HEADER */

        .header {
            background-color: var(--accent-color);
            color: white;
            padding: 25px 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: 0.3s;
        }


        .header h1 {
            font-size: 27px;
            margin-bottom: 5px;
        }


        .header p {
            font-size: 13px;
            opacity: 0.85;
        }


        .session-box {
            background-color: rgba(255, 255, 255, 0.2);
            padding: 10px 18px;
            border-radius: 25px;
            font-size: 13px;
        }


        /* MAIN CONTAINER */

        .container {
            max-width: 1000px;
            margin: 40px auto;
            padding: 0 20px;
        }


        /* WELCOME CARD */

        .welcome-card {
            background-color: white;
            border-radius: 15px;
            padding: 30px;
            margin-bottom: 25px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
            transition: 0.3s;
        }


        .dark-theme .welcome-card {
            background-color: #1f2937;
        }


        .welcome-card h2 {
            color: var(--accent-color);
            margin-bottom: 8px;
        }


        .welcome-card p {
            color: #6b7280;
            line-height: 1.6;
        }


        .dark-theme .welcome-card p {
            color: #d1d5db;
        }


        /* DASHBOARD GRID */

        .dashboard {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 25px;
        }


        /* SETTINGS CARD */

        .settings-card,
        .storage-card {
            background-color: white;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
            transition: 0.3s;
        }


        .dark-theme .settings-card,
        .dark-theme .storage-card {
            background-color: #1f2937;
        }


        .card-title {
            margin-bottom: 25px;
        }


        .card-title h2 {
            margin-bottom: 5px;
        }


        .card-title p {
            color: #6b7280;
            font-size: 13px;
        }


        .dark-theme .card-title p {
            color: #9ca3af;
        }


        /* SETTING GROUP */

        .setting-group {
            margin-bottom: 22px;
        }


        label {
            display: block;
            font-weight: bold;
            font-size: 14px;
            margin-bottom: 8px;
        }


        input,
        select {
            width: 100%;
            padding: 11px 13px;
            border: 2px solid #e5e7eb;
            border-radius: 8px;
            outline: none;
            font-size: 14px;
        }


        input:focus,
        select:focus {
            border-color: var(--accent-color);
        }


        /* COLOR OPTIONS */

        .color-options {
            display: flex;
            gap: 12px;
        }


        .color-button {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            border: 4px solid transparent;
            cursor: pointer;
            transition: 0.3s;
        }


        .color-button:hover {
            transform: scale(1.1);
        }


        .purple {
            background-color: #7c3aed;
        }


        .blue {
            background-color: #2563eb;
        }


        .green {
            background-color: #059669;
        }


        .orange {
            background-color: #ea580c;
        }


        .pink {
            background-color: #db2777;
        }


        /* BUTTONS */

        .button-area {
            display: flex;
            gap: 10px;
            margin-top: 25px;
        }


        .save-button,
        .reset-button {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }


        .save-button {
            background-color: var(--accent-color);
            color: white;
        }


        .save-button:hover {
            opacity: 0.85;
            transform: translateY(-2px);
        }


        .reset-button {
            background-color: #e5e7eb;
            color: #374151;
        }


        .reset-button:hover {
            background-color: #d1d5db;
        }


        /* STORAGE INFORMATION */

        .storage-item {
            padding: 15px;
            background-color: #f9fafb;
            border-radius: 9px;
            margin-bottom: 13px;
        }


        .dark-theme .storage-item {
            background-color: #374151;
        }


        .storage-item small {
            display: block;
            color: #6b7280;
            margin-bottom: 5px;
        }


        .dark-theme .storage-item small {
            color: #d1d5db;
        }


        .storage-item strong {
            color: var(--accent-color);
            word-break: break-word;
        }


        /* STORAGE LABEL */

        .storage-label {
            display: inline-block;
            padding: 5px 10px;
            background-color: #ede9fe;
            color: #6d28d9;
            border-radius: 15px;
            font-size: 11px;
            font-weight: bold;
            margin-bottom: 15px;
        }


        .session-label {
            background-color: #dbeafe;
            color: #1d4ed8;
            margin-top: 10px;
        }


        /* SUCCESS MESSAGE */

        #message {
            display: none;
            margin-top: 20px;
            padding: 13px;
            border-radius: 8px;
            background-color: #dcfce7;
            color: #166534;
            text-align: center;
            font-weight: bold;
            font-size: 13px;
        }


        /* RESPONSIVE */

        @media (max-width: 750px) {

            .dashboard {
                grid-template-columns: 1fr;
            }


            .header {
                padding: 20px;
                flex-direction: column;
                gap: 15px;
                text-align: center;
            }

        }


    </style>

</head>


<body>


    <!-- HEADER -->

    <div class="header">

        <div>

            <h1>Preference Manager</h1>

            <p>Customize and save your application settings</p>

        </div>


        <div class="session-box">

            Session Visits:

            <strong id="visitCount">1</strong>

        </div>

    </div>



    <!-- MAIN CONTENT -->

    <div class="container">


        <!-- WELCOME SECTION -->

        <div class="welcome-card">

            <h2 id="welcomeText">

                Welcome, User!

            </h2>


            <p>

                Customize your dashboard preferences below.
                Theme, accent color and font size are stored
                permanently using localStorage, while your name
                and visit count are maintained using sessionStorage.

            </p>

        </div>



        <div class="dashboard">


            <!-- SETTINGS SECTION -->

            <div class="settings-card">


                <div class="card-title">

                    <h2>Application Settings</h2>

                    <p>
                        Choose your preferred appearance settings.
                    </p>

                </div>



                <!-- USER NAME -->

                <div class="setting-group">

                    <label for="userName">

                        Display Name

                    </label>


                    <input
                        type="text"
                        id="userName"
                        placeholder="Enter your name"
                    >

                </div>



                <!-- THEME -->

                <div class="setting-group">

                    <label for="theme">

                        Select Theme

                    </label>


                    <select id="theme">

                        <option value="light">
                            Light Theme
                        </option>

                        <option value="dark">
                            Dark Theme
                        </option>

                    </select>

                </div>



                <!-- FONT SIZE -->

                <div class="setting-group">

                    <label for="fontSize">

                        Font Size

                    </label>


                    <select id="fontSize">

                        <option value="14px">
                            Small
                        </option>

                        <option value="16px">
                            Medium
                        </option>

                        <option value="18px">
                            Large
                        </option>

                    </select>

                </div>



                <!-- ACCENT COLOR -->

                <div class="setting-group">

                    <label>

                        Accent Color

                    </label>


                    <div class="color-options">


                        <button
                            class="color-button purple"
                            onclick="selectColor('#7c3aed')"
                        ></button>


                        <button
                            class="color-button blue"
                            onclick="selectColor('#2563eb')"
                        ></button>


                        <button
                            class="color-button green"
                            onclick="selectColor('#059669')"
                        ></button>


                        <button
                            class="color-button orange"
                            onclick="selectColor('#ea580c')"
                        ></button>


                        <button
                            class="color-button pink"
                            onclick="selectColor('#db2777')"
                        ></button>


                    </div>

                </div>



                <!-- BUTTONS -->

                <div class="button-area">


                    <button
                        class="save-button"
                        onclick="savePreferences()"
                    >

                        Save Preferences

                    </button>


                    <button
                        class="reset-button"
                        onclick="resetPreferences()"
                    >

                        Reset Settings

                    </button>


                </div>



                <div id="message">

                    Preferences saved successfully!

                </div>


            </div>



            <!-- STORAGE DETAILS -->

            <div class="storage-card">


                <div class="card-title">

                    <h2>Stored Data</h2>

                    <p>
                        Current browser storage information.
                    </p>

                </div>



                <span class="storage-label">

                    localStorage

                </span>



                <div class="storage-item">

                    <small>Theme</small>

                    <strong id="storedTheme">
                        Not Saved
                    </strong>

                </div>



                <div class="storage-item">

                    <small>Font Size</small>

                    <strong id="storedFont">
                        Not Saved
                    </strong>

                </div>



                <div class="storage-item">

                    <small>Accent Color</small>

                    <strong id="storedColor">
                        Not Saved
                    </strong>

                </div>



                <span class="storage-label session-label">

                    sessionStorage

                </span>



                <div class="storage-item">

                    <small>User Name</small>

                    <strong id="storedName">
                        Not Saved
                    </strong>

                </div>



                <div class="storage-item">

                    <small>Session Visits</small>

                    <strong id="storedVisits">
                        1
                    </strong>

                </div>


            </div>


        </div>


    </div>



    <script>


        /* DEFAULT ACCENT COLOR */


        let selectedColor = "#7c3aed";




        /* ---------------------------------

           SELECT ACCENT COLOR

        --------------------------------- */


        function selectColor(color) {


            selectedColor = color;


            document.documentElement.style.setProperty(

                "--accent-color",

                selectedColor

            );


        }




        /* ---------------------------------

           SAVE USER PREFERENCES

        --------------------------------- */


        function savePreferences() {


            let userName =

                document.getElementById("userName").value.trim();


            let theme =

                document.getElementById("theme").value;


            let fontSize =

                document.getElementById("fontSize").value;



            /* INPUT VALIDATION */


            if (userName === "") {


                alert("Please enter your display name.");


                return;

            }



            /* ---------------------------------

               SAVE USING localStorage

            --------------------------------- */


            localStorage.setItem(

                "selectedTheme",

                theme

            );


            localStorage.setItem(

                "selectedFontSize",

                fontSize

            );


            localStorage.setItem(

                "selectedAccentColor",

                selectedColor

            );



            /* ---------------------------------

               SAVE USING sessionStorage

            --------------------------------- */


            sessionStorage.setItem(

                "userName",

                userName

            );



            /* APPLY SAVED PREFERENCES */


            applyPreferences();



            /* UPDATE STORAGE DISPLAY */


            displayStoredData();



            /* SUCCESS MESSAGE */


            let message =

                document.getElementById("message");


            message.style.display = "block";


            setTimeout(function() {


                message.style.display = "none";


            }, 3000);



            /* CONSOLE OUTPUT */


            console.log(

                "Theme saved in localStorage:",

                theme

            );


            console.log(

                "Font size saved in localStorage:",

                fontSize

            );


            console.log(

                "Accent color saved in localStorage:",

                selectedColor

            );


            console.log(

                "Username saved in sessionStorage:",

                userName

            );


        }




        /* ---------------------------------

           APPLY SAVED PREFERENCES

        --------------------------------- */


        function applyPreferences() {


            /* GET DATA FROM localStorage */


            let savedTheme =

                localStorage.getItem("selectedTheme");


            let savedFontSize =

                localStorage.getItem("selectedFontSize");


            let savedColor =

                localStorage.getItem("selectedAccentColor");



            /* GET DATA FROM sessionStorage */


            let savedName =

                sessionStorage.getItem("userName");



            /* APPLY THEME */


            if (savedTheme === "dark") {


                document.body.classList.add("dark-theme");


            }


            else {


                document.body.classList.remove("dark-theme");


            }



            /* APPLY FONT SIZE */


            if (savedFontSize) {


                document.body.style.fontSize =

                    savedFontSize;


            }



            /* APPLY ACCENT COLOR */


            if (savedColor) {


                selectedColor = savedColor;


                document.documentElement.style.setProperty(

                    "--accent-color",

                    savedColor

                );


            }



            /* DISPLAY USER NAME */


            if (savedName) {


                document.getElementById(

                    "welcomeText"

                ).textContent =

                    "Welcome, " + savedName + "!";


            }


        }




        /* ---------------------------------

           DISPLAY STORED DATA

        --------------------------------- */


        function displayStoredData() {


            let savedTheme =

                localStorage.getItem("selectedTheme");


            let savedFont =

                localStorage.getItem("selectedFontSize");


            let savedColor =

                localStorage.getItem("selectedAccentColor");


            let savedName =

                sessionStorage.getItem("userName");


            let visits =

                sessionStorage.getItem("sessionVisits");



            document.getElementById(

                "storedTheme"

            ).textContent = savedTheme || "Not Saved";



            document.getElementById(

                "storedFont"

            ).textContent = savedFont || "Not Saved";



            document.getElementById(

                "storedColor"

            ).textContent = savedColor || "Not Saved";



            document.getElementById(

                "storedName"

            ).textContent = savedName || "Not Saved";



            document.getElementById(

                "storedVisits"

            ).textContent = visits || "1";


        }




        /* ---------------------------------

           RESET PREFERENCES

        --------------------------------- */


        function resetPreferences() {


            /* REMOVE localStorage DATA */


            localStorage.removeItem("selectedTheme");


            localStorage.removeItem("selectedFontSize");


            localStorage.removeItem("selectedAccentColor");



            /* REMOVE sessionStorage DATA */


            sessionStorage.removeItem("userName");



            /* RESET DEFAULT VALUES */


            selectedColor = "#7c3aed";


            document.documentElement.style.setProperty(

                "--accent-color",

                selectedColor

            );


            document.body.classList.remove("dark-theme");


            document.body.style.fontSize = "16px";


            document.getElementById("theme").value = "light";


            document.getElementById("fontSize").value = "16px";


            document.getElementById("userName").value = "";


            document.getElementById(

                "welcomeText"

            ).textContent = "Welcome, User!";



            displayStoredData();



            console.log("Preferences have been reset.");


        }




        /* ---------------------------------

           SESSION VISIT COUNTER

        --------------------------------- */


        function updateSessionVisits() {


            let visits =

                sessionStorage.getItem("sessionVisits");



            if (visits) {


                visits = Number(visits) + 1;


            }


            else {


                visits = 1;


            }



            sessionStorage.setItem(

                "sessionVisits",

                visits

            );


            document.getElementById(

                "visitCount"

            ).textContent = visits;


        }




        /* ---------------------------------

           LOAD SAVED SETTINGS

        --------------------------------- */


        window.addEventListener("load", function() {


            updateSessionVisits();


            applyPreferences();


            displayStoredData();



            /* SET FORM VALUES */


            let savedTheme =

                localStorage.getItem("selectedTheme");


            let savedFont =

                localStorage.getItem("selectedFontSize");


            let savedName =

                sessionStorage.getItem("userName");



            if (savedTheme) {


                document.getElementById("theme").value =

                    savedTheme;


            }


            if (savedFont) {


                document.getElementById("fontSize").value =

                    savedFont;


            }


            if (savedName) {


                document.getElementById("userName").value =

                    savedName;


            }


        });


    </script>


</body>

</html>
